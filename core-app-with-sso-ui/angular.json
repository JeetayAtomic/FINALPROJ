{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "core-app-with-sso-ui": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class":       { "skipTests": true },
        "@schematics/angular:component":   { "skipTests": true },
        "@schematics/angular:directive":   { "skipTests": true },
        "@schematics/angular:guard":       { "skipTests": true },
        "@schematics/angular:interceptor": { "skipTests": true },
        "@schematics/angular:pipe":        { "skipTests": true },
        "@schematics/angular:resolver":    { "skipTests": true },
        "@schematics/angular:service":     { "skipTests": true }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "assets": [
                { "glob": "**/*", "input": "public" },
                { "glob": "web.config", "input": "src" }
              ],
            "styles": [ "node_modules/primeicons/primeicons.css", "src/styles.css" ]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial",           "maximumWarning": "2.23mb", "maximumError": "2MB" },
                { "type": "anyComponentStyle", "maximumWarning": "2.24mb",   "maximumError": "2MB" }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "configurations": {
            "production":  { "buildTarget": "core-app-with-sso-ui:build:production"  },
            "development": { "buildTarget": "core-app-with-sso-ui:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    },

    "election-tracker": {
      "projectType": "application",
      "root": "projects/election-tracker",
      "sourceRoot": "projects/election-tracker/src",
      "prefix": "et",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/election-tracker/src/main.ts",
            "index": "projects/election-tracker/src/index.html",
            "tsConfig": "projects/election-tracker/tsconfig.app.json",
            "outputPath": "dist/election-tracker",
            "styles": [ "projects/election-tracker/src/styles.css" ]
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "projects/election-tracker/src/environments/environment.ts",
                  "with": "projects/election-tracker/src/environments/environment.prod.ts"
                }
              ]
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4210,
            "proxyConfig": "projects/election-tracker/proxy.conf.json"
          },
          "configurations": {
            "production":  { "buildTarget": "election-tracker:build:production"  },
            "development": { "buildTarget": "election-tracker:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
